<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Acesso ao Sistema</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --brand-950: #07172c;
      --brand-900: #0b1f4b;
      --brand-800: #0d2a66;
      --forest-900: #0d311d;
      --forest-800: #16421f;
      --forest-700: #1f5b2e;
      --forest-100: #e8f4ec;
      --gold: #c99a2e;
      --text-900: #102033;
      --text-700: #334155;
      --text-500: #64748b;
      --border: #d5dde6;
      --card: #ffffff;
    }

    body {
      min-height: 100vh;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: var(--text-900);
      background:
        linear-gradient(135deg, rgba(7, 23, 44, 0.96), rgba(13, 49, 29, 0.92));
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .shell {
      width: min(100%, 1380px);
      min-height: min(88vh, 860px);
      display: grid;
      grid-template-columns: minmax(0, 1.06fr) minmax(420px, 0.94fr);
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.28);
      border-radius: 14px;
      background:
        linear-gradient(180deg, rgba(248, 250, 252, 0.9), rgba(248, 250, 252, 0.7) 18%, rgba(7, 23, 44, 0.08)),
        rgba(255, 255, 255, 0.72);
      box-shadow: 0 26px 70px rgba(0, 0, 0, 0.35);
    }

    .intro {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 100%;
      padding: 42px 48px;
      color: #ffffff;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.86) 0%, rgba(20, 63, 42, 0.28) 22%, rgba(5, 24, 24, 0.9) 72%),
        linear-gradient(135deg, rgba(11, 31, 75, 0.72), rgba(13, 49, 29, 0.78)),
        linear-gradient(160deg, #dfe9e3 0%, #8aa896 24%, #2e5941 52%, #081d20 100%);
    }

    .intro::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), transparent 26%),
        repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.05) 0 1px, transparent 1px 64px);
      pointer-events: none;
    }

    .intro > * {
      position: relative;
      z-index: 1;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 24px;
      color: var(--forest-900);
    }

    .brand-logo {
      width: 126px;
      height: 126px;
      object-fit: contain;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(13, 49, 29, 0.15);
      padding: 10px;
      box-shadow: 0 12px 28px rgba(7, 23, 44, 0.18);
    }

    .brand-title {
      max-width: 640px;
    }

    .brand-title h1 {
      font-size: clamp(1.8rem, 3.2vw, 2.75rem);
      line-height: 1.16;
      font-weight: 800;
      color: var(--forest-900);
    }

    .brand-title p {
      margin-top: 10px;
      font-size: clamp(1rem, 1.5vw, 1.28rem);
      font-weight: 700;
      color: var(--forest-900);
    }

    .message {
      max-width: 620px;
      margin-top: 110px;
      text-shadow: 0 2px 12px rgba(0, 0, 0, 0.35);
    }

    .message h2 {
      max-width: 560px;
      font-size: clamp(1.6rem, 3vw, 2.45rem);
      line-height: 1.18;
      margin-bottom: 24px;
    }

    .message p {
      max-width: 620px;
      font-size: 1.08rem;
      line-height: 1.55;
    }

    .features {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      margin-top: 48px;
      max-width: 680px;
    }

    .feature {
      min-height: 128px;
      padding: 0 18px;
      text-align: center;
      border-right: 1px solid rgba(255, 255, 255, 0.32);
    }

    .feature:last-child {
      border-right: none;
    }

    .feature svg {
      width: 40px;
      height: 40px;
      margin-bottom: 16px;
    }

    .feature strong {
      display: block;
      font-size: 0.88rem;
      margin-bottom: 10px;
    }

    .feature span {
      display: block;
      font-size: 0.84rem;
      line-height: 1.42;
    }

    .legal {
      display: flex;
      align-items: center;
      gap: 16px;
      width: min(100%, 520px);
      margin-top: 44px;
      padding: 18px 22px;
      border-radius: 10px;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(8px);
      font-size: 0.98rem;
      line-height: 1.45;
    }

    .login-panel {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 56px 48px;
      background: rgba(247, 250, 248, 0.88);
    }

    .card {
      width: min(100%, 560px);
      background: var(--card);
      border: 1px solid rgba(213, 221, 230, 0.95);
      border-radius: 12px;
      box-shadow: 0 18px 42px rgba(15, 23, 42, 0.14);
      padding: 44px 38px;
    }

    .lock {
      width: 76px;
      height: 76px;
      display: grid;
      place-items: center;
      margin: 0 auto 20px;
      border-radius: 50%;
      background: var(--forest-800);
      color: #ffffff;
      box-shadow: 0 10px 24px rgba(22, 66, 31, 0.25);
    }

    .card h2 {
      color: var(--forest-900);
      text-align: center;
      font-size: 1.7rem;
      line-height: 1.2;
      margin-bottom: 8px;
    }

    .subtitle {
      color: var(--text-700);
      text-align: center;
      margin-bottom: 28px;
      font-size: 1rem;
    }

    form {
      display: grid;
      gap: 18px;
    }

    label {
      display: block;
      margin-bottom: 8px;
      font-size: 0.92rem;
      font-weight: 700;
      color: var(--text-900);
    }

    .field {
      position: relative;
    }

    .field svg {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      width: 20px;
      height: 20px;
      color: var(--text-500);
      pointer-events: none;
    }

    input,
    select {
      width: 100%;
      min-height: 52px;
      padding: 13px 48px 13px 50px;
      border: 1px solid var(--border);
      border-radius: 7px;
      background: #ffffff;
      color: var(--text-900);
      font-size: 0.98rem;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    select {
      appearance: none;
      cursor: pointer;
    }

    input:focus,
    select:focus {
      border-color: var(--forest-700);
      box-shadow: 0 0 0 3px rgba(31, 91, 46, 0.14);
    }

    .toggle-password {
      position: absolute;
      top: 50%;
      right: 12px;
      transform: translateY(-50%);
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      border: none;
      border-radius: 6px;
      background: transparent;
      color: var(--text-500);
      cursor: pointer;
    }

    .toggle-password svg {
      position: static;
      transform: none;
      pointer-events: auto;
    }

    .select-arrow {
      position: absolute;
      top: 50%;
      right: 16px;
      transform: translateY(-50%);
      color: var(--text-700);
      pointer-events: none;
    }

    .submit {
      width: 100%;
      min-height: 54px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-top: 4px;
      border: none;
      border-radius: 7px;
      background: var(--forest-800);
      color: #ffffff;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      transition: background 0.2s, transform 0.2s;
    }

    .submit:hover {
      background: var(--forest-900);
      transform: translateY(-1px);
    }

    .help {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      color: var(--forest-900);
      text-decoration: none;
      font-size: 0.96rem;
      margin: 10px 0 22px;
    }

    .notice {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 18px;
      border-radius: 8px;
      border: 1px solid #b8dcc5;
      background: var(--forest-100);
      color: #17351f;
      line-height: 1.42;
    }

    .notice strong {
      display: block;
      margin-bottom: 3px;
    }

    .error {
      border: 1px solid #fecaca;
      border-radius: 8px;
      background: #fee2e2;
      color: #991b1b;
      padding: 12px 14px;import express from 'express';
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';
import routes from '../routes/route.js'; // rotas externas
import { createServer } from 'http';

const app = express();

app.use(express.urlencoded({ extended: true }));
app.set('view engine', 'ejs');

// Caminho correto das views e public
const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

// Servir arquivos estáticos
app.use(express.static(join(__dirname, '../public')));
app.set('views', join(__dirname, '../views'));

// Rotas
app.use(routes)
app.listen(3001)
// Exporta o handler compatível com Vercel
export default app;
      font-size: 0.92rem;
    }

    .footer {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      padding: 20px 42px;
      background: linear-gradient(90deg, var(--forest-900), #0c3a1b);
      color: #ffffff;
    }

    .footer-brand,
    .footer-secure {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .footer-brand strong {
      display: block;
      margin-bottom: 2px;
    }

    .footer-brand span,
    .footer-secure,
    .copyright {
      color: rgba(255, 255, 255, 0.86);
      font-size: 0.92rem;
    }

    @media (max-width: 980px) {
      body {
        padding: 16px;
      }

      .shell {
        grid-template-columns: 1fr;
      }

      .intro {
        min-height: auto;
        padding: 30px;
      }

      .brand {
        align-items: flex-start;
      }

      .brand-logo {
        width: 86px;
        height: 86px;
      }

      .message {
        margin-top: 46px;
      }

      .features {
        grid-template-columns: 1fr;
        gap: 14px;
      }

      .feature {
        min-height: auto;
        display: flex;
        align-items: center;
        gap: 14px;
        text-align: left;
        border-right: none;
        border-bottom: 1px solid rgba(255, 255, 255, 0.24);
        padding: 0 0 14px;
      }

      .feature:last-child {
        border-bottom: none;
      }

      .feature svg {
        flex: 0 0 auto;
        margin: 0;
      }

      .login-panel {
        padding: 28px;
      }

      .card {
        padding: 32px 24px;
      }

      .footer {
        flex-direction: column;
        align-items: flex-start;
        padding: 22px 30px;
      }
    }

    @media (max-width: 560px) {
      body {
        padding: 0;
      }

      .shell {
        min-height: 100vh;
        border-radius: 0;
        border: none;
      }

      .intro {
        padding: 24px 18px;
      }

      .brand {
        gap: 14px;
      }

      .brand-logo {
        width: 68px;
        height: 68px;
      }

      .brand-title h1 {
        font-size: 1.25rem;
      }

      .brand-title p {
        font-size: 0.9rem;
      }

      .message h2 {
        font-size: 1.4rem;
      }

      .message p,
      .legal {
        font-size: 0.92rem;
      }

      .login-panel {
        padding: 20px 14px;
      }

      .card {
        padding: 26px 18px;
      }

      .footer {
        padding: 20px 18px;
      }
    }
  </style>
  <link rel="stylesheet" href="/auth.css">
</head>
<body>
  <main class="shell">
    <section class="intro" aria-label="Apresentação do sistema">
      <div>
        <div class="brand">
          <img class="brand-logo" src="/imagem/logoverde.png" alt="Logo RO">
          <div class="brand-title">
            <h1>Sistema de Registro de Ocorrências Ambientais</h1>
            <p>Delegacia de Crimes Ambientais</p>
          </div>
        </div>

        <div class="message">
          <h2>Denúncias de crimes ambientais e maus-tratos aos animais</h2>
          <p>Registre e acompanhe denúncias com segurança, contribuindo para a proteção do meio ambiente e dos animais.</p>
        </div>

        <div class="features">
          <div class="feature">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              <path d="m9 12 2 2 4-5"></path>
            </svg>
            <div>
              <strong>Sigilo e segurança</strong>
              <span>Dados protegidos e usados apenas para fins legais.</span>
            </div>
          </div>
          <div class="feature">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="4" y="3" width="16" height="18" rx="2"></rect>
              <path d="M8 8h8"></path>
              <path d="M8 12h8"></path>
              <path d="M8 16h5"></path>
            </svg>
            <div>
              <strong>Acompanhamento</strong>
              <span>Consulte o andamento das suas denúncias.</span>
            </div>
          </div>
          <div class="feature">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2"></rect>
              <path d="M8 17V9"></path>
              <path d="M12 17V6"></path>
              <path d="M16 17v-4"></path>
            </svg>
            <div>
              <strong>Relatórios</strong>
              <span>Informações organizadas para ações mais eficientes.</span>
            </div>
          </div>
        </div>
      </div>

      <div class="legal">
        <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 3v18"></path>
          <path d="m5 7 7-4 7 4"></path>
          <path d="M5 7 2 14h6L5 7z"></path>
          <path d="M19 7l-3 7h6l-3-7z"></path>
          <path d="M6 21h12"></path>
        </svg>
        <span>O envio de informações falsas está sujeito às penalidades previstas em lei.</span>
      </div>
    </section>

    <section class="login-panel" aria-label="Formulário de login">
      <div class="card">
        <div class="lock">
          <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="5" y="11" width="14" height="10" rx="2"></rect>
            <path d="M8 11V7a4 4 0 0 1 8 0v4"></path>
          </svg>
        </div>
        <h2>Acesso ao Sistema</h2>
        <p class="subtitle">Faça login para acessar o sistema de denúncias</p>

        <form action="/login" method="POST">
          <% if (typeof erro !== 'undefined' && erro) { %>
            <div class="error"><%= erro %></div>
          <% } %>

          <div>
            <label for="nome">Nome de usuário</label>
            <div class="field">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21a8 8 0 0 0-16 0"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
              <input id="nome" name="nome" type="text" placeholder="Digite seu nome de usuário" autocomplete="username" required>
            </div>
          </div>

          <div>
            <label for="senha">Senha</label>
            <div class="field">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="5" y="11" width="14" height="10" rx="2"></rect>
                <path d="M8 11V7a4 4 0 0 1 8 0v4"></path>
              </svg>
              <input id="senha" name="senha" type="password" placeholder="Digite sua senha" autocomplete="current-password" required>
              <button class="toggle-password" type="button" aria-label="Mostrar senha" onclick="togglePassword()">
                <svg id="eyeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
              </button>
            </div>
          </div>

          <div>
            <label for="tipo">Tipo de usuário</label>
            <div class="field">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              <select id="tipo" name="tipo" required>
                <option value="geral">Geral</option>
                <option value="admin">Admin</option>
              </select>
              <span class="select-arrow">⌄</span>
            </div>
          </div>

          <button class="submit" type="submit">
            <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
              <path d="m10 17 5-5-5-5"></path>
              <path d="M15 12H3"></path>
            </svg>
            Entrar
          </button>
        </form>

        <a class="help" href="/cadastro">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 16v-4"></path>
            <path d="M12 8h.01"></path>
          </svg>
          Criar uma conta
        </a>

        <div class="notice">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <path d="m9 12 2 2 4-5"></path>
          </svg>
          <div>
            <strong>Sistema destinado ao registro oficial de denúncias ambientais.</strong>
            <span>Seus dados estão protegidos e são utilizados apenas para fins legais.</span>
          </div>
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="footer-brand">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          <path d="M8.5 12.5 11 15l4.5-6"></path>
        </svg>
        <div>
          <strong>Sistema de Registro de Ocorrências Ambientais</strong>
          <span>Delegacia de Crimes Ambientais</span>
        </div>
      </div>
      <div class="copyright">© 2026 Todos os direitos reservados.</div>
      <div class="footer-secure">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="5" y="11" width="14" height="10" rx="2"></rect>
          <path d="M8 11V7a4 4 0 0 1 8 0v4"></path>
        </svg>
        <span>Ambiente seguro</span>
      </div>
    </footer>
  </main>

  <script>
    function togglePassword() {
      const input = document.getElementById('senha');
      const button = document.querySelector('.toggle-password');
      const isHidden = input.type === 'password';
      input.type = isHidden ? 'text' : 'password';
      button.setAttribute('aria-label', isHidden ? 'Ocultar senha' : 'Mostrar senha');
    }
  </script>
</body>
</html>
