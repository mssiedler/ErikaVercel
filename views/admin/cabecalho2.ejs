<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
 
    <% const isAdminFlag = typeof isAdmin === 'undefined' ? true : isAdmin; %>
    <title>Sistema de Denúncias Ambientais - <%= isAdminFlag ? 'Administração' : 'Área do Usuário' %></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <% const userName = currentUser && currentUser.nome ? currentUser.nome : 'Usuário'; %>
    <% const userInitials = userName.trim().split(/\s+/).slice(0, 2).map((part) => part[0]).join('').toUpperCase() || 'RO'; %>
    <% const userRoleLabel = isAdminFlag ? 'Administração' : 'Cidadão'; %>
    <% const userEmail = currentUser && currentUser.email ? currentUser.email : ''; %>
    <% const userPhone = currentUser && currentUser.numero ? currentUser.numero : ''; %>
    <%
        const notifications = typeof headerNotifications !== 'undefined' ? headerNotifications : [];
        const unreadNotifications = typeof headerUnreadNotifications !== 'undefined' ? headerUnreadNotifications : 0;
        const notificationTime = (date) => {
            const created = new Date(date);
            const diffMs = Date.now() - created.getTime();
            const diffMinutes = Math.max(0, Math.floor(diffMs / 60000));
            if (diffMinutes < 1) return 'Agora há pouco';
            if (diffMinutes < 60) return `${diffMinutes} minutos atrás`;
            const diffHours = Math.floor(diffMinutes / 60);
            if (diffHours < 24) return `${diffHours} horas atrás`;
            return created.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' });
        };
    %>
    <!-- Header -->
    <header class="header">
        <div class="header-content">
            <div class="header-left">
                <button class="menu-btn" id="menuBtn">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
                <div class="imagem">
                    <img src="/imagem/logoverde.png" alt="Logo">
                </div>
                <div class="header-title">
                    <h1>Sistema de Denúncias Ambientais</h1>
                    <p>Delegacia de Crimes Ambientais</p>
                </div>
            </div>
            <div class="header-right">
                <details class="notification-menu">
                    <summary class="icon-btn notification-trigger" aria-label="Abrir notificações">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9"></path>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                        </svg>
                        <% if (unreadNotifications > 0) { %>
                            <span class="notification-badge"><%= unreadNotifications > 9 ? '9+' : unreadNotifications %></span>
                        <% } %>
                    </summary>
                    <div class="notification-dropdown">
                        <div class="notification-header">
                            <strong>Notificações</strong>
                            <% if (notifications.length) { %>
                                <a href="/notificacoes/marcar-todas-lidas">Marcar todas como lidas</a>
                            <% } %>
                        </div>
                        <div class="notification-list">
                            <% if (notifications.length) { %>
                                <% notifications.forEach((notification) => { %>
                                    <a class="notification-item <%= notification.lida ? '' : 'unread' %>" href="/notificacoes/<%= notification._id %>/ler">
                                        <span class="notification-icon notification-<%= notification.tipo || 'info' %>">
                                            <% if (['situacao', 'concluida'].includes(notification.tipo)) { %>
                                                <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M20 6 9 17l-5-5"></path>
                                                </svg>
                                            <% } else if (notification.tipo === 'providencia') { %>
                                                <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <circle cx="12" cy="12" r="10"></circle>
                                                    <polyline points="12 6 12 12 16 14"></polyline>
                                                </svg>
                                            <% } else if (notification.tipo === 'arquivo') { %>
                                                <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                                    <polyline points="14 2 14 8 20 8"></polyline>
                                                </svg>
                                            <% } else { %>
                                                <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <circle cx="12" cy="12" r="10"></circle>
                                                    <path d="M12 16v-4"></path>
                                                    <path d="M12 8h.01"></path>
                                                </svg>
                                            <% } %>
                                        </span>
                                        <span class="notification-content">
                                            <strong><%= notification.titulo %></strong>
                                            <span><%= notification.mensagem %></span>
                                            <small><%= notificationTime(notification.createdAt) %></small>
                                        </span>
                                        <% if (!notification.lida) { %>
                                            <span class="notification-dot"></span>
                                        <% } %>
                                    </a>
                                <% }) %>
                            <% } else { %>
                                <div class="notification-empty">
                                    <strong>Nenhuma notificação</strong>
                                    <span>Novas atualizações aparecerão aqui.</span>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </details>
                <details class="profile-menu">
                    <summary class="profile-trigger" aria-label="Abrir opções do perfil">
                        <div class="user-badge"><%= userInitials %></div>
                        <div class="user-info">
                            <strong>Olá, <%= userName %></strong>
                            <span><%= userRoleLabel %></span>
                        </div>
                        <svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="m6 9 6 6 6-6"></path>
                        </svg>
                    </summary>
                    <div class="profile-dropdown">
                        <div class="profile-dropdown-header">
                            <div class="user-badge profile-dropdown-avatar"><%= userInitials %></div>
                            <div>
                                <strong><%= userName %></strong>
                                <span><%= userRoleLabel %></span>
                            </div>
                        </div>
                        <div class="profile-details">
                            <% if (userEmail) { %>
                                <div class="profile-detail-item">
                                    <span>Email</span>
                                    <strong><%= userEmail %></strong>
                                </div>
                            <% } %>
                            <% if (userPhone) { %>
                                <div class="profile-detail-item">
                                    <span>Celular</span>
                                    <strong><%= userPhone %></strong>
                                </div>
                            <% } %>
                        </div>
                        <div class="profile-actions">
                            <% if (!isAdminFlag) { %>
                                <a href="/usuario/perfil" class="profile-action">
                                    <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M20 21a8 8 0 0 0-16 0"></path>
                                        <circle cx="12" cy="7" r="4"></circle>
                                    </svg>
                                    <span>Meu Perfil</span>
                                </a>
                            <% } %>
                            <a href="/logout" class="profile-action danger">
                                <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                    <path d="m16 17 5-5-5-5"></path>
                                    <path d="M21 12H9"></path>
                                </svg>
                                <span>Sair</span>
                            </a>
                        </div>
                    </div>
                </details>
            </div>
        </div>
    </header>

    <div class="main-container">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <nav class="sidebar-nav">
                <% if (isAdminFlag) { %>
                    <a href="/admin/denuncia/lst" class="nav-item <%= typeof currentSection !== 'undefined' && currentSection === 'denuncia' ? 'active' : '' %>">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                        <span>Denúncias</span>
                    </a>
                    <a href="/admin/relatorio/lst" class="nav-item <%= typeof currentSection !== 'undefined' && currentSection === 'relatorio' ? 'active' : '' %>">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="20" x2="18" y2="10"></line>
                            <line x1="12" y1="20" x2="12" y2="4"></line>
                            <line x1="6" y1="20" x2="6" y2="14"></line>
                        </svg>
                        <span>Relatórios</span>
                    </a>
                <% } else { %>
                    <a href="/usuario/denuncia/lst" class="nav-item <%= typeof currentSection !== 'undefined' && currentSection === 'denuncia' ? 'active' : '' %>">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                        <span>Minhas Denúncias</span>
                    </a>

                    <a href="/usuario/perfil" class="nav-item <%= typeof currentSection !== 'undefined' && currentSection === 'perfil' ? 'active' : '' %>">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21a8 8 0 0 0-16 0"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                        <span>Meu Perfil</span>
                    </a>
                <% } %>
            </nav>
            <div class="sidebar-bottom">
                <div class="secure-card">
                    <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                        <path d="m9 12 2 2 4-5"></path>
                    </svg>
                    <div>
                        <strong>Ambiente seguro</strong>
                        <span>Seus dados são protegidos e utilizados apenas para fins legais.</span>
                    </div>
                </div>
                <a href="/logout" class="logout-link">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <path d="m16 17 5-5-5-5"></path>
                        <path d="M21 12H9"></path>
                    </svg>
                    <span>Sair do sistema</span>
                </a>
            </div>
        </aside>

        <!-- Overlay -->
        <div class="overlay" id="overlay"></div>

        <!-- Main Content -->
        <main class="content">
