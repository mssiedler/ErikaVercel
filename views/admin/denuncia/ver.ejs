<%- include('../cabecalho2.ejs', { currentSection: 'denuncia' }) %>
<% const isAdminFlag = typeof isAdmin === 'undefined' ? true : isAdmin; %>
<% const basePath = isAdminFlag ? '/admin' : '/usuario'; %>
<% const isAnimalCase = Denuncia.especie === 'Animais'; %>
<% const tipoLabel = isAnimalCase ? 'Tipo de ocorrência' : 'Tipo de crime ambiental'; %>
<% const pageTitle = isAnimalCase ? 'Denúncia de Crime contra Animais' : 'Denúncia de Crime Ambiental'; %>
<% const crumbTitle = isAnimalCase ? 'Crimes contra Animais' : 'Crimes Ambientais'; %>
<% const dataValue = Denuncia.data ? new Date(Denuncia.data).toISOString().split('T')[0] : ''; %>
<%
    const evidencias = Array.isArray(Denuncia.evidencias) && Denuncia.evidencias.length
        ? Denuncia.evidencias
        : (Denuncia.foto ? [Denuncia.foto] : []);
    const imageExts = ['.jpg', '.jpeg', '.png', '.gif', '.webp', '.avif', '.bmp'];
    const videoExts = ['.mp4', '.webm', '.ogg', '.mov', '.avi'];
    const audioExts = ['.mp3', '.wav', '.ogg', '.m4a'];
    const getFileName = (arquivo) => String(arquivo).split(/[\\/]/).pop();
    const getFileUrl = (arquivo) => `/imagem/${encodeURIComponent(getFileName(arquivo))}`;
    const getFileExt = (arquivo) => {
        const arquivoLower = getFileName(arquivo).toLowerCase();
        const dotIndex = arquivoLower.lastIndexOf('.');
        return dotIndex >= 0 ? arquivoLower.slice(dotIndex) : '';
    };
%>

<div id="viewPage" class="page active denuncia-create denuncia-view">
    <form class="form environmental-form" action="<%= isAdminFlag ? `/admin/denuncia/edt/${Denuncia._id}` : '#' %>" method="POST" enctype="multipart/form-data">
        <div class="environmental-form-header">
            <div>
                <div class="environmental-breadcrumb">
                    <a href="<%= basePath %>/denuncia/lst" aria-label="Voltar para lista">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 12H5"></path>
                            <path d="m12 19-7-7 7-7"></path>
                        </svg>
                    </a>
                    <span>Denúncia <%= Denuncia.ndenuncia ? `#${Denuncia.ndenuncia}` : '' %> / <%= crumbTitle %></span>
                </div>
                <h2><%= pageTitle %></h2>
                <p>Confira os dados registrados e atualize as providências do caso.</p>
            </div>
        </div>

        <input type="hidden" name="descricaoSituacao" value="<%= Denuncia.descricaoSituacao || '' %>">

        <div class="environmental-grid">
            <div class="environmental-main">
                <section class="environmental-section">
                    <h3><span>1.</span> Sobre o crime <%= isAnimalCase ? 'contra animais' : 'ambiental' %></h3>
                    <div class="environmental-fields top-fields">
                        <div class="form-group">
                            <label for="descricaoSituacaoView"><%= tipoLabel %></label>
                            <input type="text" id="descricaoSituacaoView" value="<%= Denuncia.descricaoSituacao || '' %>" readonly>
                        </div>
                        <div class="form-group">
                            <label for="data">Data da ocorrência</label>
                            <input type="date" id="data" value="<%= dataValue %>" readonly>
                        </div>
                        <div class="form-group">
                            <label for="hora">Horário aproximado</label>
                            <input type="time" id="hora" value="<%= Denuncia.hora || '' %>" readonly>
                        </div>
                        <div class="form-group span-2">
                            <label for="endereco">Local da ocorrência</label>
                            <input type="text" id="endereco" value="<%= Denuncia.endereco || '' %>" readonly>
                        </div>
                        <% if (isAnimalCase) { %>
                            <div class="form-group">
                                <label for="quantidade">Quantidade de animais</label>
                                <input type="number" id="quantidade" value="<%= Denuncia.quantidade || 1 %>" readonly>
                            </div>
                        <% } else { %>
                            <div class="form-group">
                                <label for="municipio">Município</label>
                                <input type="text" id="municipio" value="<%= Denuncia.enderecoProprietario || '' %>" readonly>
                            </div>
                        <% } %>
                    </div>
                </section>

                <section class="environmental-section">
                    <h3><span>2.</span> Descrição da ocorrência</h3>
                    <div class="form-group">
                        <label for="descricao">Descrição registrada</label>
                        <textarea id="descricao" rows="6" readonly><%= Denuncia.descricao || '' %></textarea>
                    </div>
                </section>

                <section class="environmental-section">
                    <h3><span>3.</span> Evidências</h3>
                    <p class="environmental-hint">Arquivos anexados à denúncia. O admin pode manter arquivos existentes e anexar novos.</p>
                    <% if (evidencias.length) { %>
                        <div class="evidence-preview-grid">
                            <% evidencias.forEach((arquivo, index) => { %>
                                <% const arquivoNome = getFileName(arquivo); %>
                                <% const arquivoUrl = getFileUrl(arquivo); %>
                                <% const arquivoExt = getFileExt(arquivo); %>
                                <div class="evidence-preview-item">
                                    <strong>Arquivo <%= index + 1 %></strong>
                                    <% if (imageExts.includes(arquivoExt)) { %>
                                        <img src="<%= arquivoUrl %>" alt="Evidência <%= index + 1 %>">
                                    <% } else if (videoExts.includes(arquivoExt)) { %>
                                        <video controls src="<%= arquivoUrl %>"></video>
                                    <% } else if (audioExts.includes(arquivoExt)) { %>
                                        <audio controls src="<%= arquivoUrl %>"></audio>
                                    <% } else { %>
                                        <a class="evidence-file-link" href="<%= arquivoUrl %>" target="_blank" rel="noopener">Abrir arquivo</a>
                                    <% } %>
                                    <span title="<%= arquivoNome %>"><%= arquivoNome %></span>
                                    <% if (isAdminFlag) { %>
                                        <label class="evidence-keep-toggle">
                                            <input type="checkbox" name="manterEvidencias" value="<%= arquivo %>" checked>
                                            Manter arquivo
                                        </label>
                                    <% } %>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <p class="environmental-hint">Nenhuma evidência foi anexada.</p>
                    <% } %>

                    <% if (isAdminFlag) { %>
                        <label class="environmental-upload evidence-upload-edit" for="evidencias">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                <path d="m17 8-5-5-5 5"></path>
                                <path d="M12 3v12"></path>
                            </svg>
                            <span>Adicionar novas evidências</span>
                            <small>Fotos, vídeos, áudios, PDF ou outros documentos.</small>
                            <input type="file" id="evidencias" name="evidencias" multiple>
                        </label>
                        <div class="evidence-list" id="editEvidenceList"></div>
                    <% } %>
                </section>
            </div>

            <aside class="environmental-sidebar environmental-section">
                <h3><span>4.</span> Seus dados</h3>
                <div class="environmental-user-panel">
                    <p class="environmental-hint">Dados informados pelo denunciante.</p>
                    <div class="environmental-user-fields">
                        <div class="form-group">
                            <label for="nomeDenunciante">Nome completo</label>
                            <input type="text" id="nomeDenunciante" value="<%= Denuncia.nomedenunciante || '' %>" readonly>
                        </div>
                        <div class="form-group">
                            <label for="email">E-mail</label>
                            <input type="email" id="email" value="<%= Denuncia.email || '' %>" readonly>
                        </div>
                        <div class="form-group">
                            <label for="telefone">Telefone</label>
                            <input type="text" id="telefone" value="<%= Denuncia.telefone || '' %>" readonly>
                        </div>
                    </div>
                </div>
            </aside>

            <% if (isAdminFlag) { %>
                <section class="environmental-section admin-providence-section">
                    <h3><span>5.</span> Providências</h3>
                    <div class="environmental-fields providence-fields">
                        <div class="form-group">
                            <label for="situacao">Situação do caso</label>
                            <select id="situacao" name="situacao" required>
                                <option value="Pendente" <%= Denuncia.situacao === 'Pendente' ? 'selected' : '' %>>Pendente</option>
                                <option value="Em Análise" <%= Denuncia.situacao === 'Em Análise' ? 'selected' : '' %>>Em Análise</option>
                                <option value="Em Andamento" <%= Denuncia.situacao === 'Em Andamento' ? 'selected' : '' %>>Em Andamento</option>
                                <option value="Resolvida" <%= Denuncia.situacao === 'Resolvida' ? 'selected' : '' %>>Resolvida</option>
                                <option value="Arquivada" <%= Denuncia.situacao === 'Arquivada' ? 'selected' : '' %>>Arquivada</option>
                                <option value="Inativa" <%= Denuncia.situacao === 'Inativa' ? 'selected' : '' %>>Inativa</option>
                            </select>
                        </div>
                        <div class="form-group span-2">
                            <label for="providencia">Providências tomadas</label>
                            <textarea id="providencia" name="providencia" rows="5" placeholder="Descreva as ações realizadas pela equipe..."><%= Denuncia.providencia || '' %></textarea>
                        </div>
                    </div>
                </section>
            <% } %>
        </div>

        <div class="environmental-actions">
            <button type="button" class="btn btn-outline" onclick="window.location.href='<%= basePath %>/denuncia/lst'">
                Voltar
            </button>
            <% if (isAdminFlag) { %>
                <button type="submit" class="btn btn-primary">
                    Salvar alterações
                </button>
            <% } %>
        </div>
    </form>
</div>

<% if (isAdminFlag) { %>
    <script>
        const editEvidenceInput = document.getElementById('evidencias');
        const editEvidenceList = document.getElementById('editEvidenceList');

        editEvidenceInput?.addEventListener('change', () => {
            const files = Array.from(editEvidenceInput.files || []);
            if (!editEvidenceList) return;

            editEvidenceList.innerHTML = '';
            editEvidenceList.classList.toggle('has-files', files.length > 0);

            files.forEach((file, index) => {
                const item = document.createElement('div');
                const info = document.createElement('div');
                const title = document.createElement('strong');
                const name = document.createElement('span');
                const size = document.createElement('small');

                item.className = 'evidence-item';
                title.textContent = `Novo arquivo ${index + 1}`;
                name.textContent = file.name;
                name.title = file.name;
                size.textContent = `${(file.size / 1024 / 1024).toFixed(2)} MB`;

                info.append(title, name);
                item.append(info, size);
                editEvidenceList.appendChild(item);
            });
        });
    </script>
<% } %>

<%- include('../rodape.ejs') %>
