<%- include('../admin/cabecalho2.ejs', { currentSection: 'perfil', isAdmin: false }) %>

<div class="page active">
    <div class="page-header">
        <h2>Meu Perfil</h2>
        <a class="btn btn-outline" href="/logout">Sair</a>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>Dados do usuário</h3>
            <p class="card-description">Atualize suas informações de contato.</p>
        </div>
        <div class="card-content">
            <% if (typeof erro !== 'undefined' && erro) { %>
                <div class="alert-error"><%= erro %></div>
            <% } %>
            <% if (typeof sucesso !== 'undefined' && sucesso) { %>
                <div class="alert-success"><%= sucesso %></div>
            <% } %>

            <form class="form" action="/usuario/perfil" method="POST">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="nome">Nome de usuário</label>
                        <input type="text" id="nome" name="nome" value="<%= usuario.nome || '' %>" required>
                    </div>

                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" value="<%= usuario.email || '' %>" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="numero">Número de celular</label>
                    <input type="tel" id="numero" name="numero" value="<%= usuario.numero || '' %>" placeholder="(00) 00000-0000">
                </div>

                <div class="form-actions">
                    <a class="btn btn-outline" href="/usuario/denuncia/lst">Voltar</a>
                    <button class="btn btn-primary" type="submit">Salvar Perfil</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('../admin/rodape.ejs') %>
