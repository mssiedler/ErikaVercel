<%- include('../../admin/cabecalho2.ejs', { currentSection: 'denuncia', isAdmin: false }) %>
            <div id="listPage" class="page active">
                <div class="page-header">
                    <%
                        const filtroParams = typeof filtro !== 'undefined' ? filtro : {};
                        const relatorioParams = [];
                        if (filtroParams && filtroParams.email) relatorioParams.push(`email=${encodeURIComponent(filtroParams.email)}`);
                        if (filtroParams && filtroParams.cpf) relatorioParams.push(`cpf=${encodeURIComponent(filtroParams.cpf)}`);
                        if (filtroParams && filtroParams.ndenuncia) relatorioParams.push(`ndenuncia=${encodeURIComponent(filtroParams.ndenuncia)}`);
                        const relatorioUrl = relatorioParams.length
                            ? `/usuario/relatorio/lst?${relatorioParams.join('&')}`
                            : '/usuario/relatorio/lst';
                    %>
                    <div>
                        <h2>Minhas Denúncias</h2>
                        <p>Acompanhe suas denúncias registradas no sistema.</p>
                    </div>
                    <a class="btn btn-primary" href="/usuario/denuncia/add">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 5v14"></path>
                            <path d="M5 12h14"></path>
                        </svg>
                        <span>Nova Denúncia</span>
                    </a>
                </div>


                <div class="filters-card" style="margin-top: 16px;">
                    <div class="filters-grid">
                        <div class="search-box">
                            <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="11" cy="11" r="8"></circle>
                                <path d="m21 21-4.35-4.35"></path>
                            </svg>
                            <input type="text" placeholder="Buscar por número ou nome..." id="searchInput">
                        </div>
                        <select id="filterSituacao">
                            <option value="todas">Todas as situações</option>
                            <option value="Pendente">Pendente</option>
                            <option value="Em Análise">Em Análise</option>
                            <option value="Em Andamento">Em Andamento</option>
                            <option value="Resolvida">Resolvida</option>
                            <option value="Arquivada">Arquivada</option>
                        </select>
                        <select id="filterEspecie">
                            <option value="todas">Todas as espécies</option>
                            <option value="Animais">Animais</option>
                            <option value="Ambiental">Ambiental</option>
                        </select>
                    </div>
                </div>

                <div class="results-count" id="resultsCount">Exibindo 0 de 0 denúncias</div>

                <div class="table-card">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Número</th>
                                <th>Denunciante</th>
                                <th>Data/Hora</th>
                                <th>Espécie</th>
                                <th>Situação</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody id="tableBody"></tbody>
                    </table>
                </div>

               

    <script>
        const denuncias = <%- JSON.stringify(DenunciasView || []) %>;
    </script>
    <script>
        window.DENUNCIA_BASE_PATH = '/usuario';
    </script>
    <script src="/script.js"></script>

<%- include('../../admin/rodape.ejs') %>
